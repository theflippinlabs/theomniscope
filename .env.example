# Oracle Sentinel — environment variables
#
# Copy to `.env.local` and fill in the values for your deployment.
# Every VITE_ variable is exposed to the browser bundle — NEVER put
# a raw Moralis / Reservoir / Stripe secret here.

# ---------- Supabase (public, required) ----------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon public key>

# ---------- Oracle proxy (production path) ----------
# URL of the deployed `oracle-fetch` edge function. When this is set,
# the client routes ALL provider calls through the proxy — Moralis /
# GoPlus / DexScreener / Reservoir keys stay server-side.
VITE_ORACLE_PROXY_URL=https://<project-ref>.functions.supabase.co/oracle-fetch

# ---------- Stripe (billing) ----------
# URL of the deployed `stripe-checkout` edge function.
VITE_STRIPE_CHECKOUT_URL=https://<project-ref>.functions.supabase.co/stripe-checkout

# ============================================================
# Server-side secrets (set via `supabase secrets set <KEY>=<val>`)
# ============================================================
# These are NOT loaded by the Vite bundle — they are deployed to the
# Supabase edge functions. Listed here for documentation only.
#
# MORALIS_API_KEY          — Moralis on-chain data
# RESERVOIR_API_KEY        — Reservoir NFT data (optional)
# SUPABASE_URL             — auto-set by Supabase runtime
# SUPABASE_ANON_KEY        — auto-set by Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY — auto-set by Supabase runtime
# STRIPE_SECRET_KEY        — Stripe secret API key (sk_live_... / sk_test_...)
# STRIPE_WEBHOOK_SECRET    — Stripe webhook signing secret (whsec_...)
# STRIPE_PRICE_PRO         — Stripe Price ID for the Pro plan (price_...)
# STRIPE_PRICE_ELITE       — Stripe Price ID for the Elite plan (price_...)
# APP_URL                  — Public app origin, used for Stripe success/cancel URLs
